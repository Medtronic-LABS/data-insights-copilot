# ============================================================================
# Backend Service Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
#
# NOTE: For Docker deployment, use "postgres", "qdrant", "rabbitmq", "redis"
#       For local development, use "localhost" for all hostnames
# ============================================================================

# ============================================================================
# OpenAI Configuration
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0

# ============================================================================
# Embedding Model Configuration
# ============================================================================
EMBEDDING_MODEL_PATH=./models/bge-m3
EMBEDDING_MODEL_NAME=BAAI/bge-m3
VECTOR_DB_PATH=./indexes/chroma_db_advanced
HF_TOKEN=your-huggingface-token-here

# ============================================================================
# Vector Store Configuration
# ============================================================================
VECTOR_STORE_TYPE=qdrant
# For Docker: use "qdrant" | For Local: use "localhost"
QDRANT_HOST=localhost
QDRANT_PORT=6333
# For cloud Qdrant, uncomment and set:
# QDRANT_API_KEY=your-qdrant-api-key
# QDRANT_URL=https://your-cluster.qdrant.io

# ============================================================================
# INTERNAL APP DATABASE (PostgreSQL - for config storage)
# ============================================================================
# PostgreSQL database for storing users, settings, prompts, agents, etc.
# This is NOT the clinical data database (that's configured via db_connections)
# For Docker: use "postgres" | For Local: use "localhost"
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=copilot
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# ============================================================================
# Security Configuration
# ============================================================================
# JWT Secret Key - Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-for-jwt-signing-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# OIDC/Keycloak Authentication (Optional)
# ============================================================================
# Leave OIDC_ISSUER_URL empty to disable OIDC and use local auth
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=data-insights-copilot
OIDC_AUDIENCE=
OIDC_JWKS_CACHE_TTL=3600
OIDC_DEFAULT_ROLE=user
OIDC_ROLE_CLAIM=resource_access.data-insights-copilot.roles

# ============================================================================
# Server Configuration
# ============================================================================
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1
PROJECT_NAME=Data Insights AI-Copilot
VERSION=1.0.0
DEBUG=false

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# ============================================================================
# Frontend URL
# ============================================================================
FRONTEND_URL=http://localhost:5173
ALLOWED_REDIRECT_PATHS=/,/dashboard,/chat,/admin,/settings
SESSION_COOKIE_SAMESITE=lax

# ============================================================================
# Langfuse Tracing (Optional)
# ============================================================================
ENABLE_LANGFUSE=true
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
# For Docker: use "http://langfuse-web:3000" | For Local: use "http://localhost:3001"
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_TRACING_ENABLED=true

# ============================================================================
# Celery Configuration (Message Queue)
# ============================================================================
USE_CELERY_FOR_EMBEDDINGS=false
# For Docker: use "rabbitmq" and "redis" | For Local: use "localhost"
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# File Paths
# ============================================================================
LOG_FILE=./logs/backend.log
EMBEDDING_LOG_FILE=./logs/embedding.log
MODELS_PATH=./models
DATA_PATH=./data

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# RAG Configuration
# ============================================================================
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
RAG_RERANK=true
RAG_CONFIG_PATH=./config/embedding_config.yaml

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# Admin User Configuration
# ============================================================================
# CHANGE THESE IN PRODUCTION!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@secret
ADMIN_EMAIL=admin@yourdomain.com

# ============================================================================
# Hugging Face Hub Configuration
# ============================================================================
HUGGINGFACEHUB_API_TOKEN=your-huggingface-api-token

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_FOLLOWUP_QUESTIONS=true

# ============================================================================
# Testing
# ============================================================================
TEST_DATABASE_URL=
PYTEST_TIMEOUT=30
